# === LLM Provider ===
# Options: "anthropic", "openai"
# Default: auto-detected from whichever API key is set.
# LLM_PROVIDER=openai

# API key for the LLM provider.
# Anthropic:
# ANTHROPIC_API_KEY=sk-ant-...
# OpenAI-compatible (OpenAI, xAI Grok, Ollama, etc.):
# OPENAI_API_KEY=xai-...

# Base URL for OpenAI-compatible endpoints (optional).
#   xAI Grok:  https://api.x.ai/v1
#   Ollama:    http://localhost:11434/v1
# LLM_BASE_URL=https://api.x.ai/v1

# Model name (any model your provider supports).
TECHNICIAN_AI_MODEL=claude-opus-4-7

# === Embedding Provider ===
# Options: "voyage", "google", "openai"
# Default: auto-detected from whichever API key is set.
# If unset (no key), retrieval falls back to "pass all chunks to the LLM"
# (fine for a few manuals; degrades past ~20 chunks).
# EMBED_PROVIDER=google

# API keys for embedding providers:
# VOYAGE_API_KEY=pa-...
# GOOGLE_API_KEY=...
# (OpenAI embeddings use OPENAI_API_KEY)

# Embedding model (optional — each provider has a sensible default).
#   Voyage:  voyage-3-lite (512d)
#   Google:  gemini-embedding-001 (3072d default, supports truncation)
#   OpenAI:  text-embedding-3-small (1536d default, supports truncation)
# EMBED_MODEL=gemini-embedding-001

# Output dimensionality (optional). Google and OpenAI support truncation.
# If you switch embedding providers, delete data/tech.db and re-ingest.
# EMBED_DIM=512

# === Database ===
TECHNICIAN_AI_DB=./data/tech.db
