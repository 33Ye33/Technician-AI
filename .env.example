# Technician AI environment template
# Copy this file to .env and fill in your own API keys.
# Never commit real secrets.

# === LLM Provider ===
# Options: deepseek, openai, google, anthropic
# If LLM_PROVIDER is blank, the app auto-detects from available API keys.
# For China-friendly pilots, DeepSeek is preferred when DEEPSEEK_API_KEY is set.
# LLM_PROVIDER=google

# API keys. Set the one matching each provider you want factories to use.
# Factory settings only select among providers configured here; raw keys are
# never stored in the frontend.
# DEEPSEEK_API_KEY=your-deepseek-api-key
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...

# DeepSeek uses the OpenAI-compatible Chat Completions format.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible provider settings.
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Optional generic base URL for OpenAI-compatible providers.
# Examples:
#   OpenAI: leave blank
#   xAI:    https://api.x.ai/v1
#   Ollama: http://localhost:11434/v1
# LLM_BASE_URL=

# Main text model used for Ask, Diagnosis, tagging, and step-by-step mode.
# Factory-level AI settings can override this for Ask and Diagnosis.
TECHNICIAN_AI_MODEL=gemini-2.0-flash

# Vision-capable model used by Photo Ask. If unset, the app falls back to
# TECHNICIAN_AI_MODEL. Use a model that supports image input.
# TECHNICIAN_AI_VISION_MODEL=gemini-2.0-flash

# Maximum uploaded photo size for /api/ask/photo, in bytes.
PHOTO_ASK_MAX_BYTES=8388608

# === Embeddings / Retrieval ===
# Options: voyage, google, openai
# IMPORTANT: the app currently reads EMBED_PROVIDER.
# Do not set only EMBEDDING_PROVIDER; current code will ignore it.
# EMBED_PROVIDER=google
# EMBEDDING_PROVIDER=google  # documentation alias only

# Embedding provider keys.
# VOYAGE_API_KEY=pa-...
# GOOGLE_API_KEY=...
# OPENAI_API_KEY=...

# Optional embedding model and dimensions.
# Voyage: voyage-3-lite
# Google: gemini-embedding-001
# OpenAI: text-embedding-3-small
# EMBED_MODEL=gemini-embedding-001
# EMBED_DIM=512

# === Local Database ===
TECHNICIAN_AI_DB=./data/tech.db

# === Document Ingestion ===
# Enable vision extraction for image-heavy PDF pages, drawings, or circuit
# diagrams during ingestion. Requires a configured vision-capable LLM provider.
USE_VISION_INGEST=false
VISION_ALL_PAGES=false
# VISION_PAGE_RANGE=1-30
VISION_QUALITY_THRESHOLD=0.35

# Enable LLM topic/title tagging during ingestion and field knowledge capture.
# Set false for faster offline-ish demos.
USE_LLM_TAGGER=true

# === Authentication / Factory Workspace ===
# Required for the real multi-factory pilot login flow.
# Frontend also needs VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in frontend/.env.local.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-public-anon-key
# SUPABASE_JWT_SECRET=your-jwt-secret

# Test-only switch used by backend unit tests. Do not enable for a real pilot.
# TECHNICIAN_AI_AUTH_DISABLED=false

# === WhatsApp Integration (optional) ===
# Leave unset unless you are configuring the WhatsApp webhook integration.
# WHATSAPP_VERIFY_TOKEN=my-verify-token
# WHATSAPP_ACCESS_TOKEN=EAAx...
# WHATSAPP_PHONE_NUMBER_ID=123456789
# WHATSAPP_APP_SECRET=abc123...
